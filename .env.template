# Google AI API Key
# Get yours from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# Google Drive Upload (for detection pipeline)
# Create a folder in Google Drive and paste its ID here
GOOGLE_DRIVE_FOLDER_ID=folder_key_here

# Fal API key for image generation
FAL_KEY=your_fal_api_key_here

# Cloudflare Pages (for article publishing)
# Account ID: found on the right panel of your Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
# API Token: My Profile → API Tokens → Create Token (Cloudflare Pages Edit permission)
CLOUDFLARE_API_TOKEN=your_api_token_here
# Pages project name (becomes: https://YOUR_PROJECT_NAME.pages.dev)
CLOUDFLARE_PROJECT_NAME=your-project-name-here